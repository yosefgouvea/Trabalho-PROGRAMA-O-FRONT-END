<!DOCTYPE html>
<html lang="pt-br" data-theme="synthwave">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Arquivo da Ciência da Computação</title>

<link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>

</head>


<body class="bg-base-200">


<!-- NAVBAR  -->




<div class="navbar bg-base-100 shadow-sm">
  <a class="btn btn-ghost text-xl">Arquivo da Computação</a>
</div>

<div class="flex-none">

<ul class="menu menu-horizontal px-1 font-semibold">

<li><a href="#pioneiros">Pioneiros</a></li>
<li><a href="#bugs">Bugs</a></li>
<li><a href="#internet">Internet</a></li>
<li><a href="#linguagens">Linguagens</a></li>
<li><a href="#linha">Linha do Tempo</a></li>
<li><a href="#formulario">Enviar</a></li>

</ul>

</div>

</div>



<!-- HERO -->
<div
  class="hero min-h-screen"
  style="background-image: url(https://quantumzeitgeist.com/wp-content/uploads/asm.png);"
>
  <div class="hero-overlay"></div>
  <div class="hero-content text-neutral-content text-center">
    <div class="max-w-md">
      <h1 class="mb-5 text-5xl font-bold">Arquivo da Ciência da Computação!</h1>
      <p class="mb-5">
        Uma coletânea caótica de fatos históricos, curiosos e inesperados da tecnologia.
      </p>
      <a href="#pioneiros" class="btn btn-outline btn-accent">
        Explorar curiosidades </a>
    </div>
  </div>
</div>



</header>



<main class="container mx-auto px-6 py-16 space-y-24">



<!-- PIONEIROS -->

<section id="pioneiros">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Pioneiros da Computação
</h2>

<p class="opacity-70">
Grandes nomes que moldaram a tecnologia moderna
</p>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">


<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition">

<div class="card-body">

<h3 class="card-title text-secondary">
Ada Lovelace
</h3>

<p>
Considerada a primeira programadora da história.
</p>

<div class="collapse bg-base-200">

<input type="checkbox">

<div class="collapse-title font-medium">
Mais detalhes
</div>

<div class="collapse-content">
Ela escreveu um algoritmo para a Máquina Analítica no século XIX.
</div>

</div>

</div>

</div>



<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition">

<div class="card-body">

<h3 class="card-title text-secondary">
Alan Turing
</h3>

<p>
Criador do conceito de Máquina de Turing.
</p>

<blockquote class="italic text-sm opacity-80">
"Podemos ver apenas um pouco do futuro, mas o suficiente para perceber que há muito a fazer."
</blockquote>

</div>

</div>


</div>

</section>



<!-- BUGS -->

<section id="bugs">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Histórias de Bugs
</h2>

<p class="opacity-70">
Falhas que entraram para a história da computação
</p>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">


<div class="card bg-base-100 shadow-xl">

<div class="card-body">

<h3 class="card-title text-error">
Primeiro Bug
</h3>

<p>
Uma mariposa encontrada em um computador em 1947.
</p>

</div>

</div>



<div class="card bg-base-100 shadow-xl">

<div class="card-body">

<h3 class="card-title text-error">
Vírus Creeper
</h3>

<p>Primeiro vírus da história (1971).</p>

<pre class="bg-neutral text-neutral-content p-4 rounded">
I'M THE CREEPER : CATCH ME IF YOU CAN
</pre>

</div>

</div>


</div>

</section>



<!-- INTERNET -->

<section id="internet">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Curiosidades da Internet
</h2>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">


<div class="card bg-base-100 shadow-xl">

<div class="card-body">

<h3 class="card-title text-info">
Primeiro Website
</h3>

<p>
Criado em 1991 por Tim Berners-Lee.
</p>

</div>

</div>



<div class="card bg-base-100 shadow-xl">

<div class="card-body">

<h3 class="card-title text-info">
ARPANET
</h3>

<ul class="list-disc pl-6">

<li>Primeira mensagem enviada: "LO"</li>
<li>O sistema caiu antes de completar "LOGIN"</li>

</ul>

</div>

</div>



<div class="card bg-base-100 shadow-xl">

<div class="card-body">

<h3 class="card-title text-info">
Emojis ASCII
</h3>

<p class="text-2xl">
:-) &nbsp;&nbsp; ;-) &nbsp;&nbsp; :-D
</p>

</div>

</div>


</div>

</section>



<!-- LINGUAGENS -->

<section id="linguagens">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Linguagens de Programação
</h2>

</div>


<div class="overflow-x-auto">

<table class="table table-zebra text-center">

<thead class="bg-primary text-primary-content">

<tr>
<th>Linguagem</th>
<th>Ano</th>
</tr>

</thead>


<tbody>

<tr>
<td>COBOL</td>
<td>1959</td>
</tr>

<tr>
<td>C</td>
<td>1972</td>
</tr>

<tr>
<td>Python</td>
<td>1991</td>
</tr>

</tbody>

</table>

</div>

</section>



<!-- LINHA DO TEMPO -->

<section id="linha">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Linha do Tempo
</h2>

</div>


<ul class="timeline timeline-vertical">

<li>
<div class="timeline-start">1837</div>
<div class="timeline-middle">●</div>
<div class="timeline-end">Máquina Analítica</div>
</li>

<li>
<div class="timeline-start">1946</div>
<div class="timeline-middle">●</div>
<div class="timeline-end">ENIAC</div>
</li>

<li>
<div class="timeline-start">1969</div>
<div class="timeline-middle">●</div>
<div class="timeline-end">ARPANET</div>
</li>

<li>
<div class="timeline-start">1991</div>
<div class="timeline-middle">●</div>
<div class="timeline-end">Primeiro website</div>
</li>

</ul>

</section>



<!-- FORMULARIO -->

<section id="formulario">

<div class="text-center mb-10">

<h2 class="text-4xl font-bold">
Envie uma curiosidade
</h2>

</div>


<div class="flex justify-center">

<form class="card bg-base-100 shadow-xl p-8 w-full max-w-lg space-y-4">

<input type="text" placeholder="Seu nome" class="input input-bordered w-full">

<input type="email" placeholder="Seu email" class="input input-bordered w-full">


<select class="select select-bordered w-full">

<option>Pioneiros</option>
<option>Bugs</option>
<option>Internet</option>
<option>Linguagens</option>

</select>


<textarea class="textarea textarea-bordered" placeholder="Escreva sua curiosidade"></textarea>


<button class="btn btn-primary">
Enviar curiosidade
</button>

</form>

</div>

</section>


</main>



<!-- FOOTER -->

<footer class="footer footer-center p-10 bg-neutral text-neutral-content mt-20">

<div>

<p class="text-lg font-bold">
Arquivo da Ciência da Computação
</p>

<p>
© 2026 Instituto Internacional de Informações Desnecessárias
</p>

<p>
contato@computacao.com
</p>

</div>

</footer>


</body>
</html>
